{
  "name": "iaroslav-khmel/project-map",
  "description": "PHP project structure mapper for Laravel, Symfony and generic PHP projects.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2|^8.3|^8.4",
    "symfony/console": "^6.4|^7.0",
    "nikic/php-parser": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.0"
  },
  "autoload": {
    "psr-4": {
      "IaroslavKhmel\\ProjectMap\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IaroslavKhmel\\ProjectMap\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/project-map"
  ],
  "scripts": {
    "test": "phpunit"
  }
}
